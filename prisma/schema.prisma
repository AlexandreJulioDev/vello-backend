// =============================================================
//  ISP SYSTEM — Schema Prisma Completo (Vello)
//  Provedor de Internet · Multi-Tenant · Pronto para Mercado
// =============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

// =============================================================
//  ENUMS
// =============================================================

enum PerfilAdm {
  DONO
  GERENTE
}

enum PerfilFuncionario {
  TECNICO_EXTERNO
  SUPORTE_INTERNO
}

enum StatusContrato {
  ATIVO
  SUSPENSO
  CANCELADO
}

enum StatusFatura {
  PENDENTE
  PAGO
  ATRASADO
  CANCELADO
}

enum MetodoPagamento {
  PIX
  BOLETO
  CARTAO_CREDITO
}

enum StatusAtendimento {
  PENDENTE
  EM_EXECUCAO
  CONCLUIDO
  CANCELADO
}

enum TipoAtendimento {
  INSTALACAO
  MANUTENCAO
  SUPORTE
  CANCELAMENTO
  VISITA_TECNICA
}

enum PrioridadeAtendimento {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

enum StatusRede {
  OPERANTE
  MANUTENCAO
  QUEDA_TOTAL
}

enum TipoPontoRede {
  OLT
  CTO
  SPLITTER
  POSTE
  CAIXA_HERMETICA
}

enum CanalNotificacao {
  EMAIL
  WHATSAPP
  SMS
  PUSH
}

enum TipoEquipamento {
  ONU
  ROTEADOR
  SWITCH
  CABO
  OUTROS
}

// =============================================================
//  TENANT — PROVEDOR (A EMPRESA)
// =============================================================

model Provedor {
  id_provedor   Int      @id @default(autoincrement())
  nome_fantasia String
  razao_social  String
  cnpj          String
  slug          String
  telefone      String?
  email         String?
  logo_url      String?
  ativo         Boolean  @default(true)
  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  administradores Administrador[]
  funcionarios    Funcionario[]
  clientes        Cliente[]
  planos          Plano[]
  contratos       Contrato[]
  faturas         Fatura[]
  atendimentos    Atendimento[]
  rotas_rede      RotaRede[]
  pontos_rede     PontoRede[]
  equipamentos    Equipamento[]
  notificacoes    Notificacao[]
  audit_logs      AuditLog[]

  @@unique([cnpj])
  @@unique([slug])
  @@map("provedores")
}

// =============================================================
//  USUÁRIOS INTERNOS — EQUIPE
// =============================================================

model Administrador {
  id_adm        Int       @id @default(autoincrement())
  id_provedor   Int
  nome          String
  email         String
  senha_hash    String
  perfil        PerfilAdm
  ativo         Boolean   @default(true)
  criado_em     DateTime  @default(now())
  atualizado_em DateTime  @updatedAt

  provedor Provedor @relation(fields: [id_provedor], references: [id_provedor])

  @@unique([id_provedor, email])
  @@index([id_provedor])
  @@map("administradores")
}

model Funcionario {
  id_funcionario Int               @id @default(autoincrement())
  id_provedor    Int
  nome           String
  email          String
  senha_hash     String
  telefone       String?
  foto_url       String?
  perfil         PerfilFuncionario
  ativo          Boolean           @default(true)
  criado_em      DateTime          @default(now())
  atualizado_em  DateTime          @updatedAt

  provedor     Provedor      @relation(fields: [id_provedor], references: [id_provedor])
  atendimentos Atendimento[] @relation("TecnicoResponsavel")

  @@unique([id_provedor, email])
  @@index([id_provedor])
  @@map("funcionarios")
}

// =============================================================
//  CLIENTE E ENDEREÇO
// =============================================================

model Cliente {
  id_cliente           Int       @id @default(autoincrement())
  id_provedor          Int
  nome                 String
  cpf                  String
  rg                   String?
  data_nascimento      DateTime
  email                String
  senha_hash           String
  telefone             String
  telefone_alt         String?
  protocolo_instalacao String?   @unique
  data_instalacao      DateTime?
  mac_address_rede     String?
  ativo                Boolean   @default(true)
  criado_em            DateTime  @default(now())
  atualizado_em        DateTime  @updatedAt

  provedor     Provedor      @relation(fields: [id_provedor], references: [id_provedor])
  endereco     Endereco?
  contratos    Contrato[]
  faturas      Fatura[]
  atendimentos Atendimento[]
  notificacoes Notificacao[]

  @@unique([id_provedor, email])
  @@unique([id_provedor, cpf])
  @@index([id_provedor])
  @@map("clientes")
}

model Endereco {
  id_endereco Int                                    @id @default(autoincrement())
  id_cliente  Int                                    @unique
  cep         String
  rua         String
  numero      String
  bairro      String
  cidade      String
  estado      String
  complemento String?
  referencia  String?
  coordenadas Unsupported("geometry(Point, 4326)")?

  cliente Cliente @relation(fields: [id_cliente], references: [id_cliente])

  @@map("enderecos")
}

// =============================================================
//  PLANOS E CONTRATOS
// =============================================================

model Plano {
  id_plano            Int      @id @default(autoincrement())
  id_provedor         Int
  nome                String
  velocidade_down     Int
  velocidade_up       Int
  preco               Decimal  @db.Decimal(10, 2)
  descricao           String?  @db.Text
  fidelidade_meses    Int      @default(0)
  portas_consumidas   Int      @default(0)
  banda_compartilhada Boolean  @default(false)
  ativo               Boolean  @default(true)
  criado_em           DateTime @default(now())

  provedor  Provedor   @relation(fields: [id_provedor], references: [id_provedor])
  contratos Contrato[]

  @@index([id_provedor])
  @@map("planos")
}

model Contrato {
  id_contrato    Int            @id @default(autoincrement())
  id_provedor    Int
  id_cliente     Int
  id_plano       Int
  id_ponto_rede  Int?

  data_inicio    DateTime
  data_fim       DateTime?
  dia_vencimento Int            @default(10)
  status         StatusContrato @default(ATIVO)
  observacoes    String?        @db.Text
  criado_em      DateTime       @default(now())
  atualizado_em  DateTime       @updatedAt

  cliente    Cliente    @relation(fields: [id_cliente], references: [id_cliente])
  plano      Plano      @relation(fields: [id_plano], references: [id_plano])
  provedor   Provedor   @relation(fields: [id_provedor], references: [id_provedor])
  ponto_rede PontoRede? @relation(fields: [id_ponto_rede], references: [id_ponto])

  faturas      Fatura[]
  equipamentos Equipamento[]
  historico    HistoricoContrato[]

  @@index([id_provedor])
  @@index([id_cliente])
  @@index([id_provedor, status])
  @@map("contratos")
}

model HistoricoContrato {
  id              Int            @id @default(autoincrement())
  id_contrato     Int
  status_anterior StatusContrato
  status_novo     StatusContrato
  motivo          String?
  alterado_por    String?
  alterado_em     DateTime       @default(now())

  contrato Contrato @relation(fields: [id_contrato], references: [id_contrato])

  @@index([id_contrato])
  @@map("historico_contratos")
}

// =============================================================
//  EQUIPAMENTOS DO CLIENTE
// =============================================================

model Equipamento {
  id_equipamento Int             @id @default(autoincrement())
  id_provedor    Int
  id_contrato    Int
  tipo           TipoEquipamento
  marca          String?
  modelo         String?
  numero_serie   String?
  mac_address    String?
  instalado_em   DateTime        @default(now())
  devolvido_em   DateTime?
  ativo          Boolean         @default(true)
  observacoes    String?         @db.Text

  provedor Provedor @relation(fields: [id_provedor], references: [id_provedor])
  contrato Contrato @relation(fields: [id_contrato], references: [id_contrato])

  @@index([id_provedor])
  @@index([id_contrato])
  @@map("equipamentos")
}

// =============================================================
//  FINANCEIRO E FATURAMENTO
// =============================================================

model Fatura {
  id_fatura        Int      @id @default(autoincrement())
  id_provedor      Int
  id_cliente       Int
  id_contrato      Int
  valor            Decimal  @db.Decimal(10, 2)
  valor_pago       Decimal? @db.Decimal(10, 2)
  data_emissao     DateTime @default(now())
  data_vencimento  DateTime
  data_pagamento   DateTime?
  mes_referencia   String

  status           StatusFatura     @default(PENDENTE)
  metodo_pagamento MetodoPagamento?

  pix_copia_cola       String? @db.Text
  link_boleto          String? @db.Text
  id_transacao_gateway String?
  observacoes          String? @db.Text

  cliente  Cliente  @relation(fields: [id_cliente], references: [id_cliente])
  contrato Contrato @relation(fields: [id_contrato], references: [id_contrato])
  provedor Provedor @relation(fields: [id_provedor], references: [id_provedor])

  @@unique([id_contrato, mes_referencia])
  @@index([id_provedor, status])
  @@index([id_cliente])
  @@index([id_contrato])
  @@index([data_vencimento])
  @@map("faturas")
}

// =============================================================
//  SUPORTE TÉCNICO — ATENDIMENTOS
// =============================================================

model Atendimento {
  id_atendimento     Int                   @id @default(autoincrement())
  id_provedor        Int
  id_cliente         Int
  id_funcionario     Int?
  titulo             String
  descricao          String                @db.Text
  tipo               TipoAtendimento
  prioridade         PrioridadeAtendimento @default(MEDIA)
  status             StatusAtendimento     @default(PENDENTE)
  data_agendamento   DateTime?
  criado_em          DateTime              @default(now())
  atualizado_em      DateTime              @updatedAt
  finalizado_em      DateTime?
  nota_avaliacao     Int?
  comentario_cliente String?               @db.Text

  cliente  Cliente      @relation(fields: [id_cliente], references: [id_cliente])
  tecnico  Funcionario? @relation("TecnicoResponsavel", fields: [id_funcionario], references: [id_funcionario])
  provedor Provedor     @relation(fields: [id_provedor], references: [id_provedor])

  @@index([id_provedor, status])
  @@index([id_cliente])
  @@index([id_funcionario])
  @@map("atendimentos")
}

// =============================================================
//  INFRAESTRUTURA DE REDE
// =============================================================

model RotaRede {
  id_rota          Int        @id @default(autoincrement())
  id_provedor      Int
  nome_rota        String
  descricao        String?    @db.Text
  ponto_referencia String?
  status           StatusRede @default(OPERANTE)
  criado_em        DateTime   @default(now())

  provedor    Provedor    @relation(fields: [id_provedor], references: [id_provedor])
  pontos_rede PontoRede[]

  @@index([id_provedor])
  @@map("rotas_rede")
}

model PontoRede {
  id_ponto      Int                                    @id @default(autoincrement())
  id_provedor   Int
  id_rota       Int
  nome          String
  tipo          TipoPontoRede
  portas_total  Int                                    @default(8)
  portas_livres Int                                    @default(8)
  status        StatusRede                             @default(OPERANTE)
  endereco_ref  String?
  coordenadas   Unsupported("geometry(Point, 4326)")?
  criado_em     DateTime                               @default(now())
  atualizado_em DateTime                               @updatedAt

  provedor  Provedor   @relation(fields: [id_provedor], references: [id_provedor])
  rota      RotaRede   @relation(fields: [id_rota], references: [id_rota])
  contratos Contrato[]

  @@index([id_provedor])
  @@index([id_rota])
  @@map("pontos_rede")
}

// =============================================================
//  NOTIFICAÇÕES
// =============================================================

model Notificacao {
  id_notificacao Int              @id @default(autoincrement())
  id_provedor    Int
  id_cliente     Int
  canal          CanalNotificacao
  assunto        String
  mensagem       String           @db.Text
  enviado        Boolean          @default(false)
  enviado_em     DateTime?
  erro           String?          @db.Text
  criado_em      DateTime         @default(now())

  cliente  Cliente  @relation(fields: [id_cliente], references: [id_cliente])
  provedor Provedor @relation(fields: [id_provedor], references: [id_provedor])

  @@index([id_provedor, enviado])
  @@index([id_cliente])
  @@map("notificacoes")
}

// =============================================================
//  AUDITORIA E LOGS DE ALTERAÇÃO
// =============================================================

model AuditLog {
  id           Int      @id @default(autoincrement())
  id_provedor  Int
  tabela       String
  acao         String
  dados_antes  Json?
  dados_depois Json?
  usuario      String?
  ip           String?
  criado_em    DateTime @default(now())

  provedor Provedor @relation(fields: [id_provedor], references: [id_provedor])

  @@index([id_provedor])
  @@map("audit_logs")
}